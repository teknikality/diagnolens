# Backend API base URL.
# Leave empty to auto-detect from the hostname serving the page (works on LAN).
# Set explicitly if the backend is on a different host or port.
#
# Examples:
#   VITE_API_BASE=
#   VITE_API_BASE=http://localhost:8000
#   VITE_API_BASE=http://192.168.0.107:8000
VITE_API_BASE=
